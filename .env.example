# Discord Selfbot Configuration
# Copy this file to .env and fill in your credentials

# =============================================================================
# DISCORD AUTHENTICATION (Choose ONE method)
# =============================================================================

# Method 1: Discord User Token (RECOMMENDED - faster, more reliable)
# Get your token from Discord Developer Tools:
# 1. Open Discord in browser
# 2. Press F12 to open DevTools
# 3. Go to Application > Local Storage > https://discord.com
# 4. Find "token" and copy the value (remove quotes)
DISCORD_USER_TOKEN=your_token_here

# Method 2: Email/Password (Fallback - slower, may trigger security checks)
# Uncomment and fill in if not using token:
# DISCORD_EMAIL=your_email@example.com
# DISCORD_PASSWORD=your_password

# =============================================================================
# HERMES API CONFIGURATION
# =============================================================================

# URL for Hermes API (the AI that generates responses)
HERMES_API_URL=http://127.0.0.1:3000/api/chat

# =============================================================================
# RATE LIMITING (Optional - defaults shown)
# =============================================================================

# Maximum messages per second (keep this low to avoid detection)
MAX_MSGS_PER_SEC=5

# Daily message quota
DAILY_QUOTA=10000

# Minimum seconds between messages
SAFE_INTERVAL=1

# How often to check for new DMs (seconds)
POLL_INTERVAL=8

# =============================================================================
# THORNODE MONITORING (Optional)
# =============================================================================

# THORNode address you're bonded to
THORNODE_ADDRESS=thor1...

# Your bond provider address (the address that contributed bond)
THORNODE_BOND_PROVIDER=thor1...

# Discord channel ID for withdrawal alerts (optional - alerts go to console if not set)
THORNODE_ALERT_CHANNEL_ID=1234567890

# How often to poll THORNode API in seconds (default: 300 = 5 minutes)
THORNODE_POLL_INTERVAL=300

# =============================================================================
# SAFETY NOTES
# =============================================================================
#
# ⚠️  Discord selfbots are against Terms of Service
# ⚠️  Your account may be banned if detected
# ⚠️  Use conservative rate limits to minimize risk
# ⚠️  Keep this token secret - anyone with it can access your account
#
# This selfbot is configured to be conservative:
# - Max 5 messages per second
# - Max 10,000 messages per day
# - Only responds when mentioned (@inebotten)
# - No spam, no unsolicited messages
#
# =============================================================================
