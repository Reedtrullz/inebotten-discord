# Discord Selfbot Configuration
# Copy this file to .env and fill in your credentials

# =============================================================================
# DISCORD AUTHENTICATION (Choose ONE method)
# =============================================================================

# Method 1: Discord User Token (RECOMMENDED - faster, more reliable)
# Get your token from Discord Developer Tools:
# 1. Open Discord in browser
# 2. Press F12 to open DevTools
# 3. Go to Application > Local Storage > https://discord.com
# 4. Find "token" and copy the value (remove quotes)
DISCORD_USER_TOKEN=***

# Method 2: Email/Password (Fallback - slower, may trigger security checks)
# Uncomment and fill in if not using token:
# DISCORD_EMAIL=your_email@example.com
# DISCORD_PASSWORD=***

# =============================================================================
# AI PROVIDER SELECTION
# =============================================================================

# Choose your AI provider: "lm_studio" (local) or "openrouter" (cloud)
# LM Studio: Requires local installation, free, runs on your machine
# OpenRouter: Cloud API, requires API key, pay-per-use
AI_PROVIDER=lm_studio

# =============================================================================
# LM STUDIO CONFIGURATION (Local AI)
# =============================================================================

# URL for LM Studio API (the AI that generates responses)
HERMES_API_URL=http://127.0.0.1:3000/api/chat

# Temperature for LM Studio (0.0-1.0, higher = more creative)
HERMES_TEMPERATURE=0.7

# Maximum tokens for LM Studio responses
HERMES_MAX_TOKENS=200

# =============================================================================
# OPENROUTER CONFIGURATION (Cloud AI)
# =============================================================================

# Get your API key from https://openrouter.ai/keys
# Required if AI_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model to use (see https://openrouter.ai/models for available models)
# Free options:
#   - google/gemma-4-31b-it:free (recommended, superior Norwegian support and reasoning)
#   - google/gemma-3-4b-it:free
#   - meta-llama/llama-3-8b-instruct:free
#   - mistralai/mistral-7b-instruct:free
# Paid options (better quality):
#   - anthropic/claude-3-haiku
#   - openai/gpt-3.5-turbo
#   - openai/gpt-4
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Temperature for OpenRouter (0.0-1.0, higher = more creative)
OPENROUTER_TEMPERATURE=0.7

# Maximum tokens for OpenRouter responses
OPENROUTER_MAX_TOKENS=200

# OpenRouter API base URL (usually don't need to change this)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# =============================================================================
# RATE LIMITING (Optional - defaults shown)
# =============================================================================

# Maximum messages per second (keep this low to avoid detection)
MAX_MSGS_PER_SEC=5

# Daily message quota
DAILY_QUOTA=10000

# Minimum seconds between messages
SAFE_INTERVAL=1

# How often to check for new DMs (seconds)
POLL_INTERVAL=8

# =============================================================================
# GOOGLE CALENDAR INTEGRATION (Optional)
# =============================================================================

# Enable or disable Google Calendar synchronization (True/False)
GCAL_ENABLED=False

# The ID of the Google Calendar to sync with
# Usually your email address, or "primary"
GOOGLE_CALENDAR_ID=your_email@gmail.com

# =============================================================================
# WEB CONSOLE (Debug & Monitoring Dashboard)
# =============================================================================

# Enable the web console (True/False)
CONSOLE_ENABLED=True

# Host to bind the console server to
# Use 127.0.0.1 for local-only access (default, safe)
# Use 0.0.0.0 when running behind a reverse proxy in Docker
CONSOLE_HOST=0.0.0.0

# Port for the console server
CONSOLE_PORT=8080

# API key for accessing the console (leave empty to auto-generate)
# If empty, the key is printed in the logs on startup
CONSOLE_API_KEY=

# =============================================================================
# SAFETY NOTES
# =============================================================================
#
# ⚠️  Discord selfbots are against Terms of Service
# ⚠️  Your account may be banned if detected
# ⚠️  Use conservative rate limits to minimize risk
# ⚠️  Keep this token secret - anyone with it can access your account
#
# This selfbot is configured to be conservative:
# - Max 5 messages per second
# - Max 10,000 messages per day
# - Only responds when mentioned (@inebotten)
# - No spam, no unsolicited messages
#
# =============================================================================

# Search & Browser (Optional)
TAVILY_API_KEY=your_tavily_key_here
BROWSERBASE_API_KEY=your_browserbase_key_here
BROWSERBASE_PROJECT_ID=your_browserbase_project_id_here
